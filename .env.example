# Ejecutar desde el host con puertos publicados por Docker Compose:
# - CASSANDRA_HOST/KAFKA_HOST deben ser accesibles desde tu maquina (tipicamente 127.0.0.1).
#
# Si corrieras estos scripts dentro de un contenedor en la misma red Compose:
# - usa CASSANDRA_HOST=cassandra
# - usa KAFKA_HOST=kafka
CASSANDRA_HOST=127.0.0.1
CASSANDRA_PORT=9042
KAFKA_HOST=127.0.0.1
KAFKA_PORT=9092
KEYSPACE=wikimedia
TOPIC_NAME=wikimedia.recentchange
KAFKA_CONSUMER_GROUP_ID=wikimedia-cassandra-consumer
KAFKA_AUTO_OFFSET_RESET=latest
CASSANDRA_CONNECT_MAX_RETRIES=10
CASSANDRA_CONNECT_RETRY_WAIT_SECONDS=5
CASSANDRA_INSERT_MAX_RETRIES=3
CASSANDRA_INSERT_RETRY_WAIT_SECONDS=2
RAW_TABLE=recent_changes_raw
AGG_TABLE=changes_by_wiki_hour
# Mantener en false por defecto: la escritura de agregados a Cassandra es opcional y no idempotente.
ANALYTICS_WRITE_TO_CASSANDRA=false
ANALYTICS_HOST_OUTPUT_PATH=spark/output/changes_by_wiki_hour